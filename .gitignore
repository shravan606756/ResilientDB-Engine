# --- Project Specific Exclusions ---

# Database Backups (Bind Mount)
# This prevents leaking your local .sql and .archive data to GitHub
backups/
backups/*.sql
backups/*.archive

# Local development environment overrides
.env
application-local.properties

# Prevent pushing large binary artifacts from the build process
target/
*.jar
*.war

# --- IDE and System Files ---

# IntelliJ IDEA
.idea/
*.iml
*.iws
.classpath
.project
.settings/

# Mac/Windows System Files
.DS_Store
Thumbs.db